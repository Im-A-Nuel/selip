# Foundry env for contract deploy. Copy to contracts/.env and fill.
# Foundry auto-loads this .env when you run forge in the contracts/ dir.
# NEVER commit a funded private key.

# Arbitrum Sepolia testnet RPC (public default works; Alchemy/Infura is faster)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Arbitrum mainnet RPC (only needed for the mainnet deploy, later)
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# Arbiscan API key (for --verify). One key works for mainnet + sepolia.
# Get it free: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=

# Deployer/sender wallet private key (0x...). Must hold Arbitrum Sepolia ETH.
# This wallet becomes the gift sender in the demo deploy.
PRIVATE_KEY=

# Optional, for Demo.s.sol:
# DEMO_VALUE_WEI=100000000000000        # 0.0001 ETH
# DEMO_RECIPIENT=0x...                   # defaults to the sender address
